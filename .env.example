# ============================================================
# COUCH RIVALS — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   copy .env.example .env
#
# Then follow the steps below to get each key.
# ============================================================

# ----------------------------------------------------------
# 1. AWS CREDENTIALS
# ----------------------------------------------------------
# HOW TO GET:
#   Option A — AWS Sandbox / Hackathon Account:
#     1. Log in to your AWS Sandbox portal (the URL provided by hackathon organizers)
#     2. Click "Command line or programmatic access"
#     3. Copy the AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, and AWS_SESSION_TOKEN
#     4. Note: Sandbox tokens expire! You'll need to refresh them periodically.
#
#   Option B — IAM User (Personal Account):
#     1. Go to AWS Console → IAM → Users
#     2. Click "Create user" → Name it "couch-rivals-deploy"
#     3. Attach policy: "AdministratorAccess" (for hackathon speed; restrict later)
#     4. Go to the user → "Security credentials" tab
#     5. Click "Create access key" → Choose "Command Line Interface (CLI)"
#     6. Copy the Access Key ID and Secret Access Key (shown ONCE!)
#
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_SESSION_TOKEN=your_session_token_here_if_using_sandbox

# ----------------------------------------------------------
# 2. AWS REGION
# ----------------------------------------------------------
# HOW TO CHOOSE:
#   Use the region closest to you for lowest latency.
#   Must support WebSocket API Gateway (most regions do).
#   Common choices:
#     us-east-1      (N. Virginia — cheapest, most services)
#     eu-central-1   (Frankfurt — good for Europe/Bundesliga theme)
#     ap-south-1     (Mumbai — good for India)
#
AWS_REGION=us-east-1

# ----------------------------------------------------------
# 3. STACK NAME
# ----------------------------------------------------------
# The name for your CloudFormation stack. No spaces, use hyphens.
# This is used by SAM CLI during deployment.
#
STACK_NAME=couch-rivals

# ----------------------------------------------------------
# 4. S3 DEPLOYMENT BUCKET (Auto-created by SAM)
# ----------------------------------------------------------
# SAM CLI creates this automatically on first `sam deploy --guided`.
# You don't need to set this manually — SAM will ask you during
# the guided deployment and save it to samconfig.toml.
# If you want to specify one manually:
#
# SAM_DEPLOYMENT_BUCKET=your-sam-deployment-bucket

# ----------------------------------------------------------
# 5. WEBSOCKET URL (Auto-generated after deployment)
# ----------------------------------------------------------
# After running `sam deploy`, this will be in the stack outputs.
# The frontend needs this to connect to the WebSocket API.
# It will look like: wss://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod
#
# HOW TO GET (after deployment):
#   Run: aws cloudformation describe-stacks --stack-name couch-rivals --query "Stacks[0].Outputs[?OutputKey=='WebSocketURI'].OutputValue" --output text
#
VITE_WS_URL=wss://your-api-id.execute-api.us-east-1.amazonaws.com/prod

# ----------------------------------------------------------
# 6. CLOUDFRONT URL (Auto-generated after deployment)
# ----------------------------------------------------------
# After deploying, your frontend will be accessible at this URL.
#
# HOW TO GET (after deployment):
#   Run: aws cloudformation describe-stacks --stack-name couch-rivals --query "Stacks[0].Outputs[?OutputKey=='CloudFrontURL'].OutputValue" --output text
#
CLOUDFRONT_URL=https://dxxxxxxxxxx.cloudfront.net


# ============================================================
# SETUP CHECKLIST — Run these commands BEFORE deploying
# ============================================================
#
# STEP 1: Install AWS CLI
#   Download: https://aws.amazon.com/cli/
#   Windows: Download and run the MSI installer
#   Verify:  aws --version
#
# STEP 2: Install AWS SAM CLI
#   Download: https://docs.aws.amazon.com/serverless-application-model/latest/developerguide/install-sam-cli.html
#   Windows: Download and run the MSI installer
#   Verify:  sam --version
#
# STEP 3: Configure AWS Credentials
#   Run: aws configure
#   It will ask for:
#     AWS Access Key ID:     (paste from above)
#     AWS Secret Access Key: (paste from above)
#     Default region name:   us-east-1  (or your chosen region)
#     Default output format: json
#
#   For SANDBOX accounts with session tokens:
#     Set all three env vars in your terminal:
#       $env:AWS_ACCESS_KEY_ID="your_key"
#       $env:AWS_SECRET_ACCESS_KEY="your_secret"
#       $env:AWS_SESSION_TOKEN="your_token"
#
# STEP 4: Verify Access
#   Run: aws sts get-caller-identity
#   You should see your account ID and user ARN.
#
# STEP 5: Deploy Backend
#   cd backend
#   sam build
#   sam deploy --guided
#     Stack Name: couch-rivals
#     Region: us-east-1
#     Confirm changes: Y
#     Allow SAM CLI IAM role creation: Y
#     Save arguments to samconfig.toml: Y
#
# STEP 6: Deploy Frontend
#   Copy the WebSocket URL from Step 5 outputs
#   Update VITE_WS_URL in this file
#   Run: .\scripts\deploy-frontend.ps1
#
# ============================================================
